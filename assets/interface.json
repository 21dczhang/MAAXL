        {
            "name": "荣耀之地 - pvp",
            "entry": "PVP1_Start",
            "default_check": true,
            "description": "pvp自动打",
        },
        {
            "name": "日常奖励领取",
            "entry": "Daily_Task_Start",
            "default_check": true,
            "description": "日常奖励领取",
        },
        {
            "name": "凭证奖励领取",
