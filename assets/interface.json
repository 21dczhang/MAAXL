            "default_check": true,
            "description": "领取免费礼包"
        },
        {
            "name": "日程表一键收取",
            "entry": "RiChengBiao_Start",
            "default_check": true,
            "description": "日程表一键收取"
        },
        {
            "name": "升级角色10次 - 完成日常任务升级&消耗金币2w",
            "entry": "LevelUP_Start",
            "default_check": true,
            "description": "升级角色10次，以便完成日常任务"
        },
        {
            "name": "探险队-团队馈礼",
