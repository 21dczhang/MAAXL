    "interface_version": 2,
    "name": "MaaXL",
    "description": "for TKFM",
    "contact": "QQ群: Nothing",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 MaaXL!",
    // 填写项目地址和版本号可实现自动更新功能
    "github": "https://github.com/MaaXYZ/MaaPracticeBoilerplate",
    "version": "1.0.0",
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb",
            "display_short_side": 720 // 默认缩放分辨率的短边长度
        },
        {
            "name": "桌面端",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "Visual Studio",
                // 截图及控制方式，请根据项目实际情况修改
                // 文档: https://maafw.xyz/docs/2.4-ControlMethods
                "screencap": "PrintWindow", // 截图方式
                "mouse": "PostMessageWithCursorPos", // 鼠标控制方式
                "keyboard": "PostMessageWithCursorPos" // 键盘控制方式
            }
        }
    ],
    "resource": [
        {
            "name": "Tap服",
            "path": [
                "./resource"
            ]
        }
    ],
    "task": [
        {
            "name": "启动游戏",
            "entry": "StartGame_Start",
            "default_check": true,
            "description": "启动游戏ing"
        },
        {
            "name": "领取免费礼包",
